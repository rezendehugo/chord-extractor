# Use .dockerignore to exclude files from the Docker build context
# This speeds up builds and reduces image size by not copying unnecessary files

# Version control
.git
.gitignore
.github

# Development dependencies
node_modules
.npm
.eslintcache
venv
__pycache__
*.pyc
*.pyo
*.egg-info

# IDE and Editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env.local
.env.*.local

# Build outputs (we'll rebuild in Docker)
dist
build

# Testing
coverage
.nyc_output
